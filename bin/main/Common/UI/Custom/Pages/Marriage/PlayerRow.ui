$C = "../../Common.ui";

@CustomLabelStyle = LabelStyle(
    FontSize: 13,
    TextColor: #bfcdd5,
    RenderBold: true,
    RenderUppercase: true,
    HorizontalAlignment: Center,
    VerticalAlignment: Center
);

@RowButtonStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: @CustomLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: @CustomLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: @CustomLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: (...@CustomLabelStyle, TextColor: #555555)),
    Sounds: $C.@ButtonSounds,
);

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Left;
        Background: #071018(0.55);
        Padding: (Horizontal: 14, Vertical: 10);

        Label #PlayerName {
            Style: (FontSize: 16, TextColor: #f4f9ff, RenderBold: true, VerticalAlignment: Center);
            Text: "Player Name";
            FlexWeight: 1;
        }

        Label #PlayerStatus {
            Style: (FontSize: 11, TextColor: #e5c68a, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center);
            Text: "";
            Anchor: (Width: 60, Height: 18);
            Visible: false;
        }

        Group { Anchor: (Width: 10); }

        $C.@TextButton #ActionButton {
            Text: "SELECT";
            Anchor: (Width: 110, Height: 30);
            Padding: (Horizontal: 6);
            Style: @RowButtonStyle;
        }
    }

    Group { Anchor: (Height: 4); }
}
