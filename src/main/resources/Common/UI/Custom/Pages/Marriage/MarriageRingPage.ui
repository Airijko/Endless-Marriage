$C = "../../Common.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

// Native Hytale container + decorations (client-shipped, merged asset tree).
@CardPatchRing    = "../../Tiles/CardPatchRing.png";
@ContainerPatch   = "../../Common/ContainerPatch.png";
@DecorationTop    = "../../Common/ContainerDecorationTop.png";
@DecorationBottom = "../../Common/ContainerDecorationBottom.png";
@PanelRunes       = "../Memories/MemoriesRunes.png";
@HeaderTabBg      = "../../Common/HeaderTabBackground.png";

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            Anchor: (Width: 660, Height: 540);
            LayoutMode: Top;
            Background: (TexturePath: @CardPatchRing, Border: 16, Color: #8b95a8(0.7));
            Padding: (Full: 2);

            Group {
                FlexWeight: 1;
                LayoutMode: Top;
                Background: (TexturePath: @ContainerPatch, Border: 23);
                Padding: (Full: 0);

                // Custom navy header plate — rune inset + steel frame + gold title.
                Group {
                    Anchor: (Height: 40);
                    Background: #0d1a29;

                    Group {
                        Anchor: (Top: 2, Bottom: 2, Left: 2, Right: 2);
                        Background: (TexturePath: @PanelRunes, Border: 15);
                    }
                    Group {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        Background: (TexturePath: @HeaderTabBg, Border: 2);
                    }

                    Group {
                        LayoutMode: Left;
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        Padding: (Horizontal: 12);

                        Group { FlexWeight: 1; Anchor: (Top: 19, Bottom: 19); Background: #ffe2a6; }
                        Group { Anchor: (Width: 14); }

                        Label {
                            Anchor: (MaxWidth: 248, Height: 24);
                            Text: "RINGS";
                            Style: (FontSize: 17, TextColor: #ffe2a6, RenderBold: true, LetterSpacing: 3, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 12);
                        }

                        Group { Anchor: (Width: 14); }
                        Group { FlexWeight: 1; Anchor: (Top: 19, Bottom: 19); Background: #ffe2a6; }
                    }
                }

                Group {
                    LayoutMode: Top;
                    FlexWeight: 1;
                    Padding: (Horizontal: 16, Vertical: 14);

                Group { Anchor: (Height: 8); }
                $C.@PanelSeparatorFancy {}
                Group { Anchor: (Height: 6); }
                Group {
                    LayoutMode: Middle;
                    Anchor: (Height: 11);
                    Group { Anchor: (Width: 236, Height: 11); Background: (TexturePath: @DecorationTop); }
                }
                Group { Anchor: (Height: 8); }

                Label {
                    Text: "Strengthen your bond with a ring that reflects your prestige.";
                    Anchor: (Height: 16);
                    Style: (FontSize: 11, TextColor: #e8e8b0, HorizontalAlignment: Center, VerticalAlignment: Center);
                }

                Group { Anchor: (Height: 8); }

                // ---- Status Card ----
                Group {
                    LayoutMode: Top;
                    Background: #0b141f(0.88);
                    Padding: (Full: 14);

                    Group {
                        Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                        Background: #f2a2e8;
                    }

                    Group {
                        LayoutMode: Top;
                        Padding: (Left: 12);

                        Label #CurrentRingLabel {
                            Text: "No ring equipped";
                            Style: (FontSize: 16, TextColor: #c0cee5, RenderBold: true);
                            Anchor: (Height: 22);
                        }

                        Group { Anchor: (Height: 4); }

                        Label #PrestigeInfoLabel {
                            Text: "Your prestige: 0 | Spouse prestige: 0";
                            Style: (FontSize: 12, TextColor: #7a9abf);
                            Anchor: (Height: 16);
                        }
                    }
                }

                Group { Anchor: (Height: 4); }

                Label #RingInfoLabel {
                    Text: "Both partners must meet the prestige requirement.";
                    Style: (FontSize: 12, TextColor: #e8e8b0);
                    Anchor: (Height: 16);
                    Padding: (Left: 4);
                }

                Group { Anchor: (Height: 4); }

                // ---- Ring List ----
                Group #RingListScroll {
                    FlexWeight: 1;
                    LayoutMode: TopScrolling;
                    ScrollbarStyle: $C.@DefaultScrollbarStyle;
                    Background: (TexturePath: @PanelRunes, Border: 15);
                    Padding: (Full: 6);

                    Group #RingRows {
                        LayoutMode: Top;
                    }
                }

                Group { Anchor: (Height: 8); }
                Group {
                    LayoutMode: Middle;
                    Anchor: (Height: 11);
                    Group { Anchor: (Width: 236, Height: 11); Background: (TexturePath: @DecorationBottom); }
                }
                }
            }
        }
    }
}
