$C = "../../Common.ui";

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            Anchor: (Width: 720, Height: 560);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);

            // ---- Title ----
            Label {
                Text: "MARRIAGE REGISTRY";
                Anchor: (Height: 26);
                Style: (FontSize: 16, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #7a5a10; }
            Group { Anchor: (Height: 4); }

            Label {
                Text: "All active marriages on the server.";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #e8e8b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 8); }

            // ---- Count header ----
            Group {
                LayoutMode: Top;
                Background: #0b141f(0.88);
                Padding: (Full: 14);

                Group {
                    Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                    Background: #f2a2e8;
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Left: 12);

                    Label {
                        Text: "MARRIAGES";
                        Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Label #MarriageCountLabel {
                        Text: "0 active marriages";
                        Style: (FontSize: 10, TextColor: #7a9abf, VerticalAlignment: Center);
                    }
                }
            }

            Group { Anchor: (Height: 6); }

            // ---- XP overflow summary ----
            Group {
                LayoutMode: Top;
                Background: #0b141f(0.88);
                Padding: (Full: 14);

                Group {
                    Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                    Background: #f2a2e8;
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Left: 12);

                    Label {
                        Text: "XP OVERFLOW FUNNELED";
                        Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Label #OverflowTotalLabel {
                        Text: "0 XP";
                        Style: (FontSize: 11, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    }
                }
            }

            Group { Anchor: (Height: 6); }

            // ---- Empty state ----
            Label #EmptyLabel {
                Text: "No active marriages.";
                Anchor: (Height: 28);
                Style: (FontSize: 13, TextColor: #555555, HorizontalAlignment: Center, VerticalAlignment: Center);
                Visible: false;
            }

            // ---- Scrollable list ----
            Group {
                FlexWeight: 1;
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;
                Background: #040c17(0.90);
                Padding: (Full: 6);

                Group #MarriageAdminRows {
                    LayoutMode: Top;
                }
            }
        }
    }
}
