$C = "../../Common.ui";

Group {
    LayoutMode: Top;

    Group {
        LayoutMode: Top;
        Background: #0b141f(0.88);
        Padding: (Full: 12);

        Group {
            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
            Background: #f2a2e8;
        }

        Group {
            LayoutMode: Top;
            Padding: (Left: 12);

            Group {
                LayoutMode: Left;
                Anchor: (Height: 20);

                Label #OverflowRowDirection {
                    Text: "Player1 -> Player2";
                    Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                    FlexWeight: 1;
                }

                Label #OverflowRowAmount {
                    Text: "0 XP";
                    Style: (FontSize: 14, TextColor: #f2a2e8, RenderBold: true, VerticalAlignment: Center, HorizontalAlignment: End);
                    Anchor: (Width: 140);
                }
            }

            Group { Anchor: (Height: 3); }

            Group {
                LayoutMode: Left;
                Anchor: (Height: 14);

                Label #OverflowRowKind {
                    Text: "COMBAT";
                    Style: (FontSize: 10, TextColor: #9fb6d3, LetterSpacing: 1, VerticalAlignment: Center);
                    FlexWeight: 1;
                }

                Label #OverflowRowDate {
                    Text: "----";
                    Style: (FontSize: 10, TextColor: #7a9abf, VerticalAlignment: Center, HorizontalAlignment: End);
                    Anchor: (Width: 130);
                }
            }
        }
    }

    Group { Anchor: (Height: 6); }
}
