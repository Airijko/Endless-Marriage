$C = "../../Common.ui";

// Native Hytale container + decorations (client-shipped, merged asset tree).
@CardPatchRing    = "../../Tiles/CardPatchRing.png";
@ContainerPatch   = "../../Common/ContainerPatch.png";
@DecorationTop    = "../../Common/ContainerDecorationTop.png";
@DecorationBottom = "../../Common/ContainerDecorationBottom.png";
@PanelRunes       = "../Memories/MemoriesRunes.png";
@HeaderTabBg      = "../../Common/HeaderTabBackground.png";

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            Anchor: (Width: 680, Height: 560);
            LayoutMode: Top;
            Background: (TexturePath: @CardPatchRing, Border: 16, Color: #8b95a8(0.7));
            Padding: (Full: 2);

            Group {
                FlexWeight: 1;
                LayoutMode: Top;
                Background: (TexturePath: @ContainerPatch, Border: 23);
                Padding: (Horizontal: 16, Vertical: 14);

                // Custom navy header plate — rune inset + steel frame + gold title.
                Group {
                    Anchor: (Height: 40);
                    Background: #0d1a29;

                    Group {
                        Anchor: (Top: 2, Bottom: 2, Left: 2, Right: 2);
                        Background: (TexturePath: @PanelRunes, Border: 15);
                    }
                    Group {
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        Background: (TexturePath: @HeaderTabBg, Border: 2);
                    }

                    Group {
                        LayoutMode: Left;
                        Anchor: (Top: 0, Bottom: 0, Left: 0, Right: 0);
                        Padding: (Horizontal: 8);

                        Group { FlexWeight: 1; Anchor: (Top: 19, Bottom: 19); Background: #ffe2a6; }
                        Group { Anchor: (Width: 10); }

                        Label {
                            Anchor: (Width: 224, Height: 24);
                            Text: "CEREMONY";
                            Style: (FontSize: 17, TextColor: #ffe2a6, RenderBold: true, LetterSpacing: 3, HorizontalAlignment: Center, VerticalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 12);
                        }

                        Group { Anchor: (Width: 10); }
                        Group { FlexWeight: 1; Anchor: (Top: 19, Bottom: 19); Background: #ffe2a6; }
                    }
                }

                Group { Anchor: (Height: 8); }
                $C.@PanelSeparatorFancy {}
                Group { Anchor: (Height: 6); }
                Group {
                    LayoutMode: Middle;
                    Anchor: (Height: 11);
                    Group { Anchor: (Width: 236, Height: 11); Background: (TexturePath: @DecorationTop); }
                }
                Group { Anchor: (Height: 8); }

                Label #NoRoleLabel {
                    Text: "You need the Priest or Magistrate class to officiate.";
                    Style: (FontSize: 14, TextColor: #ffb347, RenderBold: true, Wrap: true);
                    Anchor: (Height: 36);
                    Visible: false;
                }

                // ---- Pending Marriages ----
                Group #MarriageSection {
                    LayoutMode: Top;

                    Group {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 14);

                        Group {
                            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                            Background: #8be0b2;
                        }

                        Group {
                            LayoutMode: Left;
                            Padding: (Left: 12);

                            Label {
                                Text: "PENDING MARRIAGES";
                                Style: (FontSize: 10, TextColor: #8be0b2, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                            }

                            Group { FlexWeight: 1; }

                            Label #MarriageCountLabel {
                                Text: "0 pending";
                                Style: (FontSize: 10, TextColor: #7a9abf, VerticalAlignment: Center);
                            }
                        }
                    }

                    Group { Anchor: (Height: 4); }

                    Group #MarriageListScroll {
                        LayoutMode: TopScrolling;
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        Background: (TexturePath: @PanelRunes, Border: 15);
                        Padding: (Full: 6);
                        Anchor: (Height: 160);

                        Group #MarriageRows {
                            LayoutMode: Top;
                        }
                    }
                }

                Group { Anchor: (Height: 10); }

                // ---- Pending Divorces ----
                Group #DivorceSection {
                    LayoutMode: Top;

                    Group {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 14);

                        Group {
                            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                            Background: #ff7b7b;
                        }

                        Group {
                            LayoutMode: Left;
                            Padding: (Left: 12);

                            Label {
                                Text: "PENDING DIVORCES";
                                Style: (FontSize: 10, TextColor: #ff7b7b, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                            }

                            Group { FlexWeight: 1; }

                            Label #DivorceCountLabel {
                                Text: "0 pending";
                                Style: (FontSize: 10, TextColor: #7a9abf, VerticalAlignment: Center);
                            }
                        }
                    }

                    Group { Anchor: (Height: 4); }

                    Group #DivorceListScroll {
                        LayoutMode: TopScrolling;
                        ScrollbarStyle: $C.@DefaultScrollbarStyle;
                        Background: (TexturePath: @PanelRunes, Border: 15);
                        Padding: (Full: 6);
                        Anchor: (Height: 160);

                        Group #DivorceRows {
                            LayoutMode: Top;
                        }
                    }
                }

                Group { Anchor: (Height: 8); }
                Group {
                    LayoutMode: Middle;
                    Anchor: (Height: 11);
                    Group { Anchor: (Width: 236, Height: 11); Background: (TexturePath: @DecorationBottom); }
                }
            }
        }
    }
}
