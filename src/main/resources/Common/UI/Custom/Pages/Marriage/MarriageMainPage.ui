$C = "../../Common.ui";

@CustomStyle = TextButtonStyle(
    Default: (Background: $C.@DefaultSquareButtonDefaultBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Hovered: (Background: $C.@DefaultSquareButtonHoveredBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Pressed: (Background: $C.@DefaultSquareButtonPressedBackground, LabelStyle: $C.@DefaultButtonLabelStyle),
    Disabled: (Background: $C.@DefaultSquareButtonDisabledBackground, LabelStyle: $C.@DefaultButtonDisabledLabelStyle),
    Sounds: $C.@ButtonSounds,
);

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            // Horizontal wrapper holding the witness panel (left), the main panel
            // (centre) and the affection side panel (right).
            // Width = 280 + 12 spacer + 720 + 12 spacer + 280 = 1304.
            LayoutMode: Left;
            Anchor: (Width: 1304, Height: 580);

        // ===== LEFT SIDE PANEL (WITNESSES) =====
        Group #WitnessPanel {
            Anchor: (Width: 280, Height: 580);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);
            Visible: false;

            // ---- Title ----
            Label {
                Text: "WITNESSES";
                Anchor: (Height: 26);
                Style: (FontSize: 16, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #7a5a10; }
            Group { Anchor: (Height: 4); }

            Label {
                Text: "Those who saw your bond sealed.";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #e8e8b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 8); }

            Label #WitnessCountLabel {
                Text: "0 witnesses";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #7a9abf, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 8); }

            Group {
                FlexWeight: 1;
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;
                Background: #040c17(0.90);
                Padding: (Full: 6);

                Group #WitnessRows {
                    LayoutMode: Top;
                }
            }
        }

        Group { Anchor: (Width: 12); }

        Group {
            Anchor: (Width: 720, Height: 580);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);

            // ---- Title ----
            Label {
                Text: "ENDLESS MARRIAGE";
                Anchor: (Height: 26);
                Style: (FontSize: 16, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #7a5a10; }
            Group { Anchor: (Height: 4); }

            Label {
                Text: "Bonds forged in adventure, sealed by fate.";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #e8e8b0, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 8); }

            // ---- Scrollable Content ----
            Group {
                FlexWeight: 1;
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;

                // ===== MARRIED PANEL =====
                Group #MarriedPanel {
                    LayoutMode: Top;
                    Visible: false;

                    // ---- Spouse Info Card ----
                    Group {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 16);

                        Group {
                            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                            Background: #f2a2e8;
                        }

                        Group {
                            LayoutMode: Top;
                            Padding: (Left: 12);

                            Group {
                                LayoutMode: Left;
                                Anchor: (Height: 14);
                                Padding: (Bottom: 6);

                                Label {
                                    Text: "SPOUSE";
                                    Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                                }
                            }

                            Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                            Group { Anchor: (Height: 8); }

                            Group {
                                LayoutMode: Left;
                                Anchor: (Height: 28);

                                Label #SpouseNameLabel {
                                    Text: "Unknown";
                                    Style: (FontSize: 20, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center);
                                    FlexWeight: 1;
                                }

                                // Shown only when EndlessGuilds' player profile card
                                // is installed (gated in Java via MenuRegistry).
                                $C.@TextButton #ViewProfileButton {
                                    Text: "VIEW PROFILE";
                                    Anchor: (Height: 24, Width: 124);
                                    Padding: (Horizontal: 10);
                                    Style: @CustomStyle;
                                    Visible: false;
                                }

                                Group { Anchor: (Width: 8); }

                                Label #SpouseOnlineLabel {
                                    Text: "OFFLINE";
                                    Style: (FontSize: 11, TextColor: #ff6666, RenderBold: true, RenderUppercase: true, VerticalAlignment: Center, HorizontalAlignment: End);
                                    Anchor: (Width: 80);
                                }
                            }

                            Group { Anchor: (Height: 8); }

                            Label #MarriageDateLabel {
                                Text: "Since: ---";
                                Style: (FontSize: 12, TextColor: #7a9abf);
                                Anchor: (Height: 16);
                            }

                            Label #OfficiantLabel {
                                Text: "";
                                Style: (FontSize: 12, TextColor: #7a9abf);
                                Anchor: (Height: 16);
                                Visible: false;
                            }
                        }
                    }

                    Group { Anchor: (Height: 8); }

                    // ---- Bonus & Home Cards ----
                    // Height fits the HOME card's tallest state (label + info + the
                    // VIEW COORDS button row) so the button stays inside the card
                    // background instead of spilling below it.
                    Group {
                        LayoutMode: Left;
                        Anchor: (Height: 100);

                        Group {
                            FlexWeight: 1;
                            LayoutMode: Top;
                            Background: #0b141f(0.88);
                            Padding: (Full: 14);

                            Group {
                                Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                                Background: #9ad4ff;
                            }

                            Group {
                                LayoutMode: Top;
                                Padding: (Left: 12);

                                Label {
                                    Text: "XP BONUS";
                                    Style: (FontSize: 10, TextColor: #9ad4ff, RenderBold: true, LetterSpacing: 2);
                                    Anchor: (Height: 14);
                                }

                                Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                                Group { Anchor: (Height: 6); }

                                Label #XpBonusLabel {
                                    Text: "+25% Discipline XP";
                                    Style: (FontSize: 14, TextColor: #ffffff, RenderBold: true);
                                    Anchor: (Height: 20);
                                }
                            }
                        }

                        Group { Anchor: (Width: 8); }

                        Group {
                            FlexWeight: 1;
                            LayoutMode: Top;
                            Background: #0b141f(0.88);
                            Padding: (Full: 14);

                            Group {
                                Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                                Background: #8be0b2;
                            }

                            Group {
                                LayoutMode: Top;
                                Padding: (Left: 12);

                                Label {
                                    Text: "HOME";
                                    Style: (FontSize: 10, TextColor: #8be0b2, RenderBold: true, LetterSpacing: 2);
                                    Anchor: (Height: 14);
                                }

                                Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                                Group { Anchor: (Height: 6); }

                                Label #HomeInfoLabel {
                                    Text: "No home set";
                                    Style: (FontSize: 13, TextColor: #c0cee5);
                                    Anchor: (Height: 20);
                                }

                                Group { Anchor: (Height: 6); }

                                // Coords are hidden by default to avoid accidental
                                // leaks (streaming / screenshots). Toggle to reveal.
                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 24);

                                    $C.@TextButton #ViewCoordsButton {
                                        Text: "VIEW COORDS";
                                        Anchor: (Height: 22, Width: 130);
                                        Padding: (Horizontal: 10);
                                        Style: @CustomStyle;
                                        Visible: false;
                                    }
                                }
                            }
                        }
                    }

                    Group { Anchor: (Height: 8); }

                    // ---- Ring Card ----
                    Group #RingCard {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 14);
                        Visible: false;

                        Group {
                            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                            Background: #f0c040;
                        }

                        Group {
                            LayoutMode: Top;
                            Padding: (Left: 12);

                            Label {
                                Text: "WEDDING RING";
                                Style: (FontSize: 10, TextColor: #f0c040, RenderBold: true, LetterSpacing: 2);
                                Anchor: (Height: 14);
                            }

                            Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                            Group { Anchor: (Height: 8); }

                            Group {
                                LayoutMode: Left;
                                Anchor: (Height: 56);

                                // Ring icon
                                Group {
                                    Anchor: (Width: 56, Height: 56);
                                    Background: #040c17(0.85);
                                    LayoutMode: Middle;
                                    Padding: (Full: 6);

                                    ItemIcon #RingIcon {
                                        Anchor: (Width: 40, Height: 40);
                                        ItemId: "Ingredient_Bar_Iron";
                                    }
                                }

                                Group { Anchor: (Width: 12); }

                                // Ring info column
                                Group {
                                    LayoutMode: Top;
                                    FlexWeight: 1;

                                    Group { Anchor: (Height: 4); }

                                    Label #RingInfoLabel {
                                        Text: "No ring equipped";
                                        Style: (FontSize: 15, TextColor: #7a9abf, RenderBold: true, VerticalAlignment: Center);
                                        Anchor: (Height: 22);
                                    }

                                    Group { Anchor: (Height: 2); }

                                    Label #RingNextLabel {
                                        Text: "";
                                        Style: (FontSize: 12, TextColor: #7a9abf, VerticalAlignment: Center);
                                        Anchor: (Height: 18);
                                    }
                                }

                                Group { Anchor: (Width: 8); }

                                // Action buttons column — single button that opens the
                                // Rings page (tier -> variation picker).
                                Group {
                                    LayoutMode: Top;
                                    Anchor: (Width: 170);

                                    $C.@TextButton #RingsButton {
                                        Text: "BROWSE RINGS";
                                        Anchor: (Height: 26);
                                        Padding: (Horizontal: 8);
                                        Style: @CustomStyle;
                                    }
                                }
                            }
                        }
                    }

                    Group { Anchor: (Height: 12); }

                    // ---- Action Buttons ----
                    Group {
                        LayoutMode: Left;
                        Anchor: (Height: 40);

                        $C.@TextButton #TpPartnerButton {
                            Text: "TP TO SPOUSE";
                            Anchor: (Height: 36);
                            Padding: (Horizontal: 12);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #HomeButton {
                            Text: "GO HOME";
                            Anchor: (Height: 36);
                            Padding: (Horizontal: 12);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #SetHomeButton {
                            Text: "SET HOME";
                            Anchor: (Height: 36);
                            Padding: (Horizontal: 12);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }
                    }

                    // Confirmation bar shown when SET HOME is pressed while a home
                    // already exists — guards against accidental overwrites.
                    Group #SetHomeConfirmBar {
                        LayoutMode: Top;
                        Background: #2a1212(0.92);
                        Padding: (Full: 10);
                        Visible: false;

                        Label {
                            Text: "Overwrite your existing home with your current location?";
                            Style: (FontSize: 12, TextColor: #ffcf80, RenderBold: true);
                            Anchor: (Height: 18);
                        }

                        Group { Anchor: (Height: 8); }

                        Group {
                            LayoutMode: Left;
                            Anchor: (Height: 32);

                            $C.@TextButton #SetHomeConfirmButton {
                                Text: "CONFIRM OVERWRITE";
                                Anchor: (Height: 30);
                                Padding: (Horizontal: 12);
                                FlexWeight: 1;
                                Style: @CustomStyle;
                            }

                            Group { Anchor: (Width: 6); }

                            $C.@TextButton #SetHomeCancelButton {
                                Text: "CANCEL";
                                Anchor: (Height: 30);
                                Padding: (Horizontal: 12);
                                FlexWeight: 1;
                                Style: @CustomStyle;
                            }
                        }
                    }

                    Group { Anchor: (Height: 6); }

                    Group {
                        LayoutMode: Left;
                        Anchor: (Height: 40);

                        $C.@TextButton #InventoryButton {
                            Text: "SPOUSE INVENTORY";
                            Anchor: (Height: 36);
                            Padding: (Horizontal: 12);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Width: 6); }

                        $C.@TextButton #OverflowLogButton {
                            Text: "BOND STATUS";
                            Anchor: (Height: 36);
                            Padding: (Horizontal: 12);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }
                    }

                    // ---- Role Section ----
                    Group #RoleSection {
                        LayoutMode: Top;
                        Visible: false;

                        Group { Anchor: (Height: 12); }

                        Group {
                            LayoutMode: Top;
                            Background: #0b141f(0.88);
                            Padding: (Full: 14);

                            Group {
                                Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                                Background: #e5c68a;
                            }

                            Group {
                                LayoutMode: Top;
                                Padding: (Left: 12);

                                Label {
                                    Text: "PRIEST / MAGISTRATE";
                                    Style: (FontSize: 10, TextColor: #e5c68a, RenderBold: true, LetterSpacing: 2);
                                    Anchor: (Height: 14);
                                }

                                Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                                Group { Anchor: (Height: 8); }

                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 36);

                                    $C.@TextButton #RecordsButton {
                                        Text: "RECORDS";
                                        Anchor: (Height: 32, Width: 140);
                                        Padding: (Horizontal: 8);
                                        Style: @CustomStyle;
                                    }

                                    Group { Anchor: (Width: 8); }

                                    $C.@TextButton #OfficiateFromMarriedButton {
                                        Text: "OFFICIATE PANEL";
                                        Anchor: (Height: 32, Width: 180);
                                        Padding: (Horizontal: 8);
                                        Style: @CustomStyle;
                                    }
                                }
                            }
                        }
                    }
                }

                // ===== UNMARRIED PANEL =====
                Group #UnmarriedPanel {
                    LayoutMode: Top;
                    Visible: false;

                    Group {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 16);

                        Label {
                            Text: "You are not married.";
                            Style: (FontSize: 18, TextColor: #c0cee5, RenderBold: true);
                            Anchor: (Height: 24);
                        }

                        Group { Anchor: (Height: 4); }

                        Label {
                            Text: "Propose to another player to begin your journey together.";
                            Style: (FontSize: 13, TextColor: #7a9abf, Wrap: true);
                            Anchor: (Height: 18);
                        }
                    }

                    Group { Anchor: (Height: 8); }

                    Group {
                        LayoutMode: Top;
                        Background: #0b141f(0.88);
                        Padding: (Full: 16);

                        Group {
                            Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                            Background: #ffb347;
                        }

                        Group {
                            LayoutMode: Top;
                            Padding: (Left: 12);

                            Label {
                                Text: "PROPOSALS";
                                Style: (FontSize: 10, TextColor: #ffb347, RenderBold: true, LetterSpacing: 2);
                                Anchor: (Height: 14);
                            }

                            Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                            Group { Anchor: (Height: 6); }

                            Label #PendingProposalLabel {
                                Text: "";
                                Style: (FontSize: 15, TextColor: #ffb347, RenderBold: true);
                                Anchor: (Height: 22);
                                Visible: false;
                            }

                            Group { Anchor: (Height: 4); }

                            Group {
                                LayoutMode: Left;
                                Anchor: (Height: 40);

                                $C.@TextButton #AcceptButton {
                                    Text: "ACCEPT";
                                    Anchor: (Width: 140, Height: 36);
                                    Padding: (Horizontal: 8);
                                    Style: @CustomStyle;
                                    Visible: false;
                                }

                                Group { Anchor: (Width: 8); }

                                $C.@CancelTextButton #DenyButton {
                                    Text: "DENY";
                                    Anchor: (Width: 140, Height: 36);
                                    Padding: (Horizontal: 8);
                                    Visible: false;
                                }
                            }

                            Group { Anchor: (Height: 4); }

                            Label #OutgoingProposalLabel {
                                Text: "";
                                Style: (FontSize: 13, TextColor: #7ec8f5);
                                Anchor: (Height: 18);
                                Visible: false;
                            }

                            Group { Anchor: (Height: 4); }

                            Label #PendingMarriageLabel {
                                Text: "";
                                Style: (FontSize: 13, TextColor: #8be0b2);
                                Anchor: (Height: 18);
                                Visible: false;
                            }

                            Group { Anchor: (Height: 4); }

                            Group {
                                LayoutMode: Left;
                                Anchor: (Height: 40);

                                $C.@TextButton #FindPriestButton {
                                    Text: "FIND PRIEST";
                                    Anchor: (Width: 170, Height: 36);
                                    Padding: (Horizontal: 8);
                                    Style: @CustomStyle;
                                    Visible: false;
                                }
                            }
                        }
                    }

                    Group { Anchor: (Height: 12); }

                    Group {
                        LayoutMode: Left;
                        Anchor: (Height: 44);

                        $C.@TextButton #ProposeButton {
                            Text: "PROPOSE TO PLAYER";
                            Anchor: (Height: 40);
                            Padding: (Horizontal: 16);
                            FlexWeight: 1;
                            Style: @CustomStyle;
                        }
                    }

                    Group #OfficiateSection {
                        LayoutMode: Top;
                        Visible: false;

                        Group { Anchor: (Height: 12); }

                        Group {
                            LayoutMode: Top;
                            Background: #0b141f(0.88);
                            Padding: (Full: 14);

                            Group {
                                Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                                Background: #e5c68a;
                            }

                            Group {
                                LayoutMode: Top;
                                Padding: (Left: 12);

                                Label {
                                    Text: "PRIEST / MAGISTRATE";
                                    Style: (FontSize: 10, TextColor: #e5c68a, RenderBold: true, LetterSpacing: 2);
                                    Anchor: (Height: 14);
                                }

                                Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                                Group { Anchor: (Height: 8); }

                                Group {
                                    LayoutMode: Left;
                                    Anchor: (Height: 36);

                                    $C.@TextButton #RecordsUnmarriedButton {
                                        Text: "RECORDS";
                                        Anchor: (Height: 32, Width: 140);
                                        Padding: (Horizontal: 8);
                                        Style: @CustomStyle;
                                    }

                                    Group { Anchor: (Width: 8); }

                                    $C.@TextButton #OfficiateButton {
                                        Text: "OFFICIATE PANEL";
                                        Anchor: (Height: 32, Width: 180);
                                        Padding: (Horizontal: 8);
                                        Style: @CustomStyle;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Group { Anchor: (Width: 12); }

        // ===== RIGHT SIDE PANEL =====
        // Companion container for piggyback / kiss / future affection options.
        Group #SidePanel {
            Anchor: (Width: 280, Height: 580);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);

            // ---- Title ----
            Label {
                Text: "AFFECTION";
                Anchor: (Height: 26);
                Style: (FontSize: 16, TextColor: #f2a2e8, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #5a2e4a; }
            Group { Anchor: (Height: 4); }

            Label {
                Text: "Bonds shared in body and heart.";
                Anchor: (Height: 16);
                Style: (FontSize: 11, TextColor: #f0d0e8, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 12); }

            // Hidden when not married — sender will toggle visibility from Java.
            Group #SideMarriedBlock {
                LayoutMode: Top;
                Visible: false;

                // ---- Spouse Progression Card (prestige + level chips) ----
                Group {
                    LayoutMode: Top;
                    Background: #0b141f(0.88);
                    Padding: (Full: 14);

                    Group {
                        Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                        Background: #f0c040;
                    }

                    Group {
                        LayoutMode: Top;
                        Padding: (Left: 12);

                        Label {
                            Text: "PROGRESSION";
                            Style: (FontSize: 10, TextColor: #f0c040, RenderBold: true, LetterSpacing: 2);
                            Anchor: (Height: 14);
                        }

                        Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                        Group { Anchor: (Height: 8); }

                        // Prestige + level chips — chips flex to share the narrow side
                        // column width. IDs match what the Java sender populates.
                        Group #SpouseProgressBadge {
                            LayoutMode: Left;
                            Anchor: (Height: 24);
                            Visible: false;

                            // Prestige chip — hidden when the spouse has no prestige.
                            Group #SpousePrestigeBadge {
                                LayoutMode: Middle;
                                FlexWeight: 1;
                                Background: #f0c040(0.13);
                                Visible: false;

                                Group {
                                    Anchor: (Width: 2, Top: 0, Left: 0, Bottom: 0);
                                    Background: #f0c040;
                                }

                                Label #SpousePrestigeLabel {
                                    Text: "PRESTIGE 0";
                                    Style: (FontSize: 11, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                                }
                            }

                            // Gap between chips — hidden alongside the prestige chip.
                            Group #SpouseBadgeGap { Anchor: (Width: 6); Visible: false; }

                            // Level chip — always shown for a married spouse.
                            Group #SpouseLevelBadge {
                                LayoutMode: Middle;
                                FlexWeight: 1;
                                Background: #9ad4ff(0.10);

                                Group {
                                    Anchor: (Width: 2, Top: 0, Left: 0, Bottom: 0);
                                    Background: #9ad4ff;
                                }

                                Label #SpouseLevelLabel {
                                    Text: "LVL 0";
                                    Style: (FontSize: 11, TextColor: #9ad4ff, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Center, VerticalAlignment: Center);
                                }
                            }
                        }
                    }
                }

                Group { Anchor: (Height: 10); }

                // ---- Piggyback Card ----
                Group {
                    LayoutMode: Top;
                    Background: #0b141f(0.88);
                    Padding: (Full: 14);

                    Group {
                        Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                        Background: #f2a2e8;
                    }

                    Group {
                        LayoutMode: Top;
                        Padding: (Left: 12);

                        Label {
                            Text: "PIGGYBACK";
                            Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2);
                            Anchor: (Height: 14);
                        }

                        Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                        Group { Anchor: (Height: 6); }

                        Label #PiggybackStatusLabel {
                            Text: "Idle";
                            Style: (FontSize: 13, TextColor: #c0cee5);
                            Anchor: (Height: 18);
                        }

                        Group { Anchor: (Height: 4); }

                        Label {
                            Text: "-25% damage taken (multiplicative).";
                            Style: (FontSize: 11, TextColor: #9fb6d3, Wrap: true);
                            Anchor: (Height: 16);
                        }

                        Group { Anchor: (Height: 8); }

                        $C.@TextButton #PiggybackButton {
                            Text: "PIGGYBACK";
                            Anchor: (Height: 32);
                            Padding: (Horizontal: 8);
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Height: 4); }

                        $C.@TextButton #CarryButton {
                            Text: "CARRY";
                            Anchor: (Height: 32);
                            Padding: (Horizontal: 8);
                            Style: @CustomStyle;
                        }

                        Group { Anchor: (Height: 4); }

                        $C.@TextButton #DismountButton {
                            Text: "DISMOUNT";
                            Anchor: (Height: 28);
                            Padding: (Horizontal: 8);
                            Style: @CustomStyle;
                            Disabled: true;
                        }
                    }
                }

                Group { Anchor: (Height: 10); }

                // ---- Kiss Card ----
                Group {
                    LayoutMode: Top;
                    Background: #0b141f(0.88);
                    Padding: (Full: 14);

                    Group {
                        Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                        Background: #ff6e9c;
                    }

                    Group {
                        LayoutMode: Top;
                        Padding: (Left: 12);

                        Label {
                            Text: "KISS";
                            Style: (FontSize: 10, TextColor: #ff6e9c, RenderBold: true, LetterSpacing: 2);
                            Anchor: (Height: 14);
                        }

                        Group { Anchor: (Height: 1); Background: #ffffff(0.07); }
                        Group { Anchor: (Height: 6); }

                        Label #KissStatusLabel {
                            Text: "Stand close to your spouse.";
                            Style: (FontSize: 11, TextColor: #c0cee5, Wrap: true);
                            Anchor: (Height: 28);
                        }

                        Group { Anchor: (Height: 4); }

                        Label #KissBuffLabel {
                            Text: "";
                            Style: (FontSize: 11, TextColor: #9fe0ff, Wrap: true);
                            Anchor: (Height: 28);
                        }

                        Group { Anchor: (Height: 6); }

                        $C.@TextButton #KissButton {
                            Text: "KISS";
                            Anchor: (Height: 32);
                            Padding: (Horizontal: 8);
                            Style: @CustomStyle;
                        }
                    }
                }
            }

            // Shown only to unmarried players, hides the marriage-only cards above.
            Group #SideUnmarriedBlock {
                LayoutMode: Top;
                Visible: false;

                Group {
                    LayoutMode: Top;
                    Background: #0b141f(0.88);
                    Padding: (Full: 14);

                    Label {
                        Text: "Affection options unlock once you are married.";
                        Style: (FontSize: 12, TextColor: #c0cee5, Wrap: true);
                        Anchor: (Height: 48);
                    }
                }
            }
        }
        }
    }
}
