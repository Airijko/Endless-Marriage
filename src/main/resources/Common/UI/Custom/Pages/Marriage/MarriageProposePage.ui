$C = "../../Common.ui";

$C.@PageOverlay {
    Group {
        LayoutMode: Middle;

        Group {
            Anchor: (Width: 620, Height: 520);
            Background: (TexturePath: "Images/ObjectivePanelContainer.png", Border: 15);
            LayoutMode: Top;
            Padding: (Full: 16);

            // ---- Title ----
            Label {
                Text: "PROPOSE";
                Anchor: (Height: 24);
                Style: (FontSize: 16, TextColor: #f0c040, RenderBold: true, RenderUppercase: true, LetterSpacing: 2, HorizontalAlignment: Center, VerticalAlignment: Center);
            }

            Group { Anchor: (Height: 1); Background: #7a5a10; }
            Group { Anchor: (Height: 8); }

            // ---- Header Card ----
            Group {
                LayoutMode: Top;
                Background: #0b141f(0.88);
                Padding: (Full: 14);

                Group {
                    Anchor: (Width: 3, Top: 0, Left: 0, Bottom: 0);
                    Background: #f2a2e8;
                }

                Group {
                    LayoutMode: Left;
                    Padding: (Left: 12);

                    Label {
                        Text: "AVAILABLE PLAYERS";
                        Style: (FontSize: 10, TextColor: #f2a2e8, RenderBold: true, LetterSpacing: 2, VerticalAlignment: Center);
                    }

                    Group { FlexWeight: 1; }

                    Label #PlayerCountLabel {
                        Text: "0 players";
                        Style: (FontSize: 10, TextColor: #7a9abf, VerticalAlignment: Center);
                    }
                }
            }

            Group { Anchor: (Height: 4); }

            Label #InstructionLabel {
                Text: "Select a player to propose marriage.";
                Style: (FontSize: 12, TextColor: #e8e8b0);
                Anchor: (Height: 16);
                Padding: (Left: 4);
            }

            Group { Anchor: (Height: 4); }

            // ---- Player List ----
            Group #PlayerListScroll {
                FlexWeight: 1;
                LayoutMode: TopScrolling;
                ScrollbarStyle: $C.@DefaultScrollbarStyle;
                Background: #040c17(0.90);
                Padding: (Full: 6);

                Group #PlayerRows {
                    LayoutMode: Top;
                }
            }
        }
    }
}
